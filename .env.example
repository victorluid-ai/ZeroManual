ZEROMANUAL_ENV=dev
CLAUDE_MODEL=claude-haiku-4-5
# eco = reglas primero, minimo LLM | balanced = mas IA | full = maxima IA | off = sin IA
ZEROMANUAL_AI_MODE=eco
CLAUDE_MAX_TOKENS=256
APPROVAL_THRESHOLD_EUR=500
ZEROMANUAL_INTERFACE_HOST=0.0.0.0
ZEROMANUAL_INTERFACE_PORT=8090
ZEROMANUAL_DB_PATH=runtime/zeromanual.db
ZEROMANUAL_WEBHOOK_SECRET=change_me_webhook_secret

ANTHROPIC_API_KEY=

# Empresa emisora (facturas PDF) — marca ZeroManual
ZEROMANUAL_COMPANY_NAME=ZeroManual
ZEROMANUAL_COMPANY_NIF=
ZEROMANUAL_COMPANY_ADDRESS=
ZEROMANUAL_DEFAULT_VAT_RATE=21
ZEROMANUAL_INVOICE_SERIES=FAC
INVOICES_OUTPUT_DIR=runtime/invoices
EXPORTS_OUTPUT_DIR=runtime/exports

# SMTP saliente (Gmail: contrasena de aplicacion)
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
SMTP_AUTO_SEND_ON_ISSUE=false

# Triggers nativos (sin n8n) — el agente se activa al detectar senales reales
EMAIL_TRIGGER_ENABLED=false
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=
EMAIL_IMAP_PASSWORD=
EMAIL_IMAP_FOLDER=INBOX
EMAIL_POLL_INTERVAL_SECONDS=60

N8N_HOST=localhost
N8N_WEBHOOK_URL=http://localhost:5678
N8N_WEBHOOK_BASE_URL=http://localhost:5678/webhook
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me

POSTGRES_DB=zeromanual
POSTGRES_USER=zeromanual
POSTGRES_PASSWORD=change_me

# n8n API (portal de clientes — duplicar workflows por cliente)
N8N_API_URL=http://localhost:5678/api/v1
N8N_API_KEY=
N8N_TEMPLATE_IDS={"google_reviews": "", "gmb_posts": ""}

# Google OAuth (tu app en Google Cloud — el cliente solo hace clic en "Autorizar")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8090/client/google/callback
